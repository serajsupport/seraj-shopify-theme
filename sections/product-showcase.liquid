{{ 'section-product-showcase.css' | asset_url | stylesheet_tag }}

<div class="product-showcase color-{{ section.settings.color_scheme }} section-{{ section.id }}-padding page-width">
  {%- if section.settings.title != blank -%}
    <h2 class="title {{ section.settings.heading_size }}{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}">
      {{ section.settings.title | escape }}
    </h2>
  {%- endif -%}

  <div class="product-showcase__grid">
    {%- for block in section.blocks -%}
      <div
        class="product-showcase__card seraj-tilt-card{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
        style="--animation-order: {{ forloop.index }};"
        {{ block.shopify_attributes }}
      >
        <a href="{{ block.settings.link | default: 'shopify://collections/all' }}" class="product-showcase__link">
          <div class="product-showcase__media">
            {%- if block.settings.image -%}
              {{
                block.settings.image
                | image_url: width: 800
                | image_tag: loading: 'lazy', sizes: '(min-width: 750px) 20vw, 50vw', widths: '200,400,600,800'
              }}
            {%- elsif block.settings.fallback_image != blank -%}
              <img
                src="{{ block.settings.fallback_image | asset_url }}"
                alt="{{ block.settings.title | escape }}"
                loading="lazy"
                width="800"
                height="800"
              >
            {%- endif -%}
          </div>
          <h3 class="product-showcase__title">{{ block.settings.title | escape }}</h3>
          {%- if block.settings.text != blank -%}
            <div class="product-showcase__text">{{ block.settings.text }}</div>
          {%- endif -%}
        </a>
      </div>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Product showcase",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "default": "Our Products",
      "label": "Heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        { "value": "h2", "label": "Small" },
        { "value": "h1", "label": "Medium" },
        { "value": "h0", "label": "Large" }
      ],
      "default": "h1",
      "label": "Heading size"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color scheme",
      "default": "scheme-2"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 44
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 36
    }
  ],
  "blocks": [
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Photo (overrides default photo below)"
        },
        {
          "type": "text",
          "id": "fallback_image",
          "label": "Default photo filename (theme asset)",
          "info": "Filename of an image already uploaded to the theme's assets folder, e.g. product-saffron.jpg"
        },
        {
          "type": "text",
          "id": "title",
          "default": "Product name",
          "label": "Title"
        },
        {
          "type": "richtext",
          "id": "text",
          "label": "Description"
        },
        {
          "type": "url",
          "id": "link",
          "label": "Link"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product showcase",
      "blocks": [
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" },
        { "type": "product_card" }
      ]
    }
  ]
}
{% endschema %}
